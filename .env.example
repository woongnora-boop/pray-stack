# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 — 클라이언트 번들에 넣지 말 것. npm run bible:import 및 /api/bible(서버) 조회에 사용
# Vercel 등 배포: 없으면 /api/bible은 anon으로만 조회합니다. bible_verses에 anon SELECT 정책·데이터 적재가 있어야 합니다.
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 공개 URL — 인증 메일 리다이렉트 등에 사용됩니다.
# 로컬: http://localhost:3000 (휴대폰 메일에서 인증 링크를 열려면 PC의 LAN IP나 ngrok URL을 쓰는 편이 안전합니다.)
# Vercel 프로덕션: https://your-domain.com (Preview는 비워 두면 요청 Host / VERCEL_URL로 추론)
NEXT_PUBLIC_SITE_URL=
